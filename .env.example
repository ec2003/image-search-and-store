DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,api
CSRF_TRUSTED_ORIGINS=http://localhost:8000
COMPOSE_DJANGO_SECRET_KEY=change-me-in-compose
COMPOSE_DEBUG=True
COMPOSE_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,api
COMPOSE_CSRF_TRUSTED_ORIGINS=http://localhost:8000
PUBLIC_WEB_USERNAME=public-web-user

USE_SQLITE=False
POSTGRES_DB=image_search
POSTGRES_USER=image_search
POSTGRES_PASSWORD=image_search_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=images
S3_REGION_NAME=us-east-1
S3_USE_SSL=False
S3_PRESIGNED_EXPIRE_SECONDS=900

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=image_assets_effnetv2_s_1280
QDRANT_TIMEOUT_SECONDS=5

IMAGE_MAX_SIZE_BYTES=10485760
IMAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
EMBEDDING_PROVIDER=image.embeddings.EfficientNetV2EmbeddingProvider
EMBEDDING_MODEL_ID=efficientnetv2-s-imagenet1k-v1
EMBEDDING_DIMENSIONS=1280
EMBEDDING_DEVICE=cpu
EMBEDDING_TORCH_THREADS=1
TORCH_HOME=/opt/torch-cache
